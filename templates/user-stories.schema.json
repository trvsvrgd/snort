{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arfm:template:user-stories",
  "title": "User Stories & QA Capabilities",
  "type": "object",
  "required": ["topic", "sections"],
  "properties": {
    "topic": { "type": "string" },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "body"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "body": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}

